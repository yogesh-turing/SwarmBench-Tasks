\n- Do not modify `tests/runtests.py` or the test runner infrastructure.\n"}}'; sleep 86400) | kimi --config-file /tmp/kimi-config.json --agent-file /tmp/single_agent.yaml --wire --yolo 2>/dev/null | (while IFS= read -r line; do echo "$line" >> /logs/agent/kimi-cli.txt; case "$line" in *'"id":"1"'*) break ;; esac; done; kill 0 2>/dev/null)
